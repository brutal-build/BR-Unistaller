<Window x:Class="BrutalUninstaller.App.Views.JunkCleanerView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BrutalUninstaller.App.ViewModels"
        mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="BR Unistaller — Junk Cleaner" Height="550" Width="700"
        WindowStartupLocation="CenterOwner" d:DataContext="{d:DesignInstance vm:JunkCleanerViewModel}">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0a0a1a"/><SolidColorBrush x:Key="Accent" Color="#00d4aa"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0"/><SolidColorBrush x:Key="TextSecondary" Color="#8892b0"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2a2a4a"/><SolidColorBrush x:Key="BgCard" Color="#1a1a2e"/>
    </Window.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#0f3460" Padding="16,12">
            <TextBlock Text="Junk Cleaner" Foreground="{StaticResource Accent}" FontSize="16" FontWeight="Bold"/>
        </Border>
        <Border Grid.Row="1" Margin="12,8,12,0" Background="{StaticResource BgCard}" Padding="12,10"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12">
                    <Run Text="Total: "/><Run Text="{Binding Items.Count, FallbackValue=0}" Foreground="{StaticResource Accent}"/><Run Text=" items"/>
                    <Run Text=" — "/><Run Text="{Binding TotalSavings, StringFormat={}{0:N0} bytes}" Foreground="{StaticResource Accent}"/><Run Text=" reclaimable"/>
                </TextBlock>
                <Button Grid.Column="1" Content="[ Scan ]" Background="#2a2a4a" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Padding="16,6" Margin="8,0" Cursor="Hand" Command="{Binding ScanCommand}"/>
                <Button Grid.Column="2" Content="[ Clean Selected ]" Background="#e63946" Foreground="White" BorderThickness="0" Padding="16,6" Cursor="Hand" Command="{Binding CleanCommand}"/>
            </Grid>
        </Border>
        <Border Grid.Row="2" Margin="12,8" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
            <ListView ItemsSource="{Binding Items}" Background="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle><Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                    <Setter Property="Padding" Value="8,6"/><Setter Property="BorderThickness" Value="0"/>
                </Style></ListView.ItemContainerStyle>
                <ListView.ItemTemplate><DataTemplate>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding Selected}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Path}" VerticalAlignment="Center" FontSize="12" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{Binding Category}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource Accent}"/>
                        <TextBlock Grid.Column="3" Text="{Binding EstimatedSize, StringFormat={}{0:N0} B}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right"/>
                    </Grid>
                </DataTemplate></ListView.ItemTemplate>
            </ListView>
        </Border>
        <Border Grid.Row="3" Background="#0f3460" Padding="16,10">
            <Button Content="[ Close ]" Background="#2a2a4a" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Padding="16,6" HorizontalAlignment="Right" Cursor="Hand" Command="{Binding CloseCommand}"/>
        </Border>
    </Grid>
</Window>
