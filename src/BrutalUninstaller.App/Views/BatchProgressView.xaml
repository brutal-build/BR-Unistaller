<Window x:Class="BrutalUninstaller.App.Views.BatchProgressView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BrutalUninstaller.App.ViewModels"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="BR Unistaller — Batch Progress"
        Height="500" Width="650" WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:BatchProgressViewModel}">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0a0a1a" />
        <SolidColorBrush x:Key="Accent" Color="#00d4aa" />
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#8892b0" />
        <SolidColorBrush x:Key="BorderColor" Color="#2a2a4a" />
    </Window.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#0f3460" Padding="16,12">
            <TextBlock Text="Batch Uninstall Progress" Foreground="{StaticResource Accent}" FontSize="16" FontWeight="Bold" />
        </Border>
        <ScrollViewer Grid.Row="1" Margin="12,8" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1a1a2e" Margin="0,4" Padding="12,10" CornerRadius="4"
                                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding AppName}"
                                           Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Status}"
                                           Foreground="{StaticResource Accent}" FontSize="12" HorizontalAlignment="Right" />
                                <Border Grid.Row="1" Grid.ColumnSpan="2" Height="20" Margin="0,6,0,0"
                                        Background="#12122a" CornerRadius="3">
                                    <Border Width="{Binding ProgressPercent, Converter={x:Null}}" 
                                            Background="{StaticResource Accent}" CornerRadius="3"
                                            HorizontalAlignment="Left" />
                                </Border>
                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                                           Foreground="{StaticResource TextSecondary}" FontSize="10" Margin="0,2,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Border Grid.Row="2" Background="#0f3460" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="{StaticResource Accent}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Completed: " /><Run Text="{Binding CompletedCount}" /> / <Run Text="{Binding TotalCount}" />
                </TextBlock>
                <Button Grid.Column="1" Content="[ Close ]" Margin="8,0" 
                        Background="#2a2a4a" Foreground="{StaticResource TextPrimary}" 
                        BorderThickness="0" Padding="16,6" Cursor="Hand" 
                        Command="{Binding CloseCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
