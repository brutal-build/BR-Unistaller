<Window x:Class="BrutalUninstaller.App.Views.StartupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BrutalUninstaller.App.ViewModels"
        mc:Ignorable="d" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="BR Unistaller — Startup Manager" Height="550" Width="750"
        WindowStartupLocation="CenterOwner" d:DataContext="{d:DesignInstance vm:StartupViewModel}">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0a0a1a"/><SolidColorBrush x:Key="Accent" Color="#00d4aa"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0"/><SolidColorBrush x:Key="TextSecondary" Color="#8892b0"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2a2a4a"/><SolidColorBrush x:Key="BgCard" Color="#1a1a2e"/>
    </Window.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#0f3460" Padding="16,12">
            <Grid>
                <TextBlock Text="Startup Manager" Foreground="{StaticResource Accent}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <Border Grid.Row="1" Margin="12,8" Background="{StaticResource BgCard}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#12122a" Padding="12,8" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="Name" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Grid.Column="2" Text="Command" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                        <TextBlock Grid.Column="3" Text="Source" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    </Grid>
                </Border>
                <ListView Grid.Row="1" ItemsSource="{Binding Entries}" Background="Transparent" BorderThickness="0">
                    <ListView.ItemContainerStyle><Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                        <Setter Property="Padding" Value="8,6"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#16213e"/></Trigger></Style.Triggers>
                    </Style></ListView.ItemContainerStyle>
                    <ListView.ItemTemplate><DataTemplate>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30"/><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="{Binding Command}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSecondary}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{Binding EntryType}" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource Accent}"/>
                        </Grid>
                    </DataTemplate></ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="#0f3460" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="[ Refresh ]" Background="#2a2a4a" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Padding="16,6" Margin="8,0" Cursor="Hand" Command="{Binding LoadEntriesCommand}"/>
                <Button Content="[ Close ]" Background="#2a2a4a" Foreground="{StaticResource TextPrimary}" BorderThickness="0" Padding="16,6" Cursor="Hand" Command="{Binding CloseCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
