<!-- BR Unistaller — Scan Results Window -->
<Window x:Class="BrutalUninstaller.App.Views.ScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BrutalUninstaller.App.ViewModels"
        xmlns:models="clr-namespace:BrutalUninstaller.Core.Models;assembly=BrutalUninstaller.Core"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="BR Unistaller — Scan Results"
        Height="600" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:ScanResultsViewModel}">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0a0a1a" />
        <SolidColorBrush x:Key="CardBg" Color="#1a1a2e" />
        <SolidColorBrush x:Key="Accent" Color="#00d4aa" />
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0" />
        <SolidColorBrush x:Key="TextSecondary" Color="#8892b0" />
        <SolidColorBrush x:Key="BorderColor" Color="#2a2a4a" />
        <SolidColorBrush x:Key="Danger" Color="#e63946" />
        <SolidColorBrush x:Key="HeaderBg" Color="#0f3460" />
        <SolidColorBrush x:Key="CatRegistry" Color="#4fc3f7" />
        <SolidColorBrush x:Key="CatFiles" Color="#ffb74d" />
        <SolidColorBrush x:Key="CatOther" Color="#ce93d8" />

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="#0a0a1a" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00e6b3" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource Danger}" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ff4757" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2a2a4a" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3a3a5a" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Found traces after: "
                           Foreground="{StaticResource TextSecondary}" FontSize="13"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding AppName, FallbackValue='Application'}"
                           Foreground="{StaticResource Accent}" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ═══ RESULTS LIST ═══ -->
        <Border Grid.Row="1" Margin="12,8" Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Categories header -->
                <Border Grid.Row="0" Background="#12122a" Padding="12,8"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="" />
                        <TextBlock Grid.Column="2" Text="Path / Description"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" />
                        <TextBlock Grid.Column="3" Text="Size"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Scrollable grouped list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,4">
                    <ItemsControl ItemsSource="{Binding GroupedResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <!-- Category header -->
                                    <Border Background="#16213e" Padding="12,6" Margin="0,4,0,0"
                                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Category}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding CategoryColor}" />
                                        </Grid>
                                    </Border>

                                    <!-- Items in category -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type models:ScanResult}">
                                                <Border Padding="8,4" Margin="4,0,4,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="80" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding Selected}"
                                                                  VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <CheckBox.Style>
                                                                <Style TargetType="CheckBox">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                                                                </Style>
                                                            </CheckBox.Style>
                                                        </CheckBox>
                                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                                   Foreground="{StaticResource TextPrimary}"
                                                                   FontSize="11" TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Grid.Column="2" Text="{Binding EstimatedSize, StringFormat={}{0:N0} B}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="11" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="{StaticResource HeaderBg}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Total: " />
                    <Run Text="{Binding TotalTraces, FallbackValue='0'}" Foreground="{StaticResource Accent}" />
                    <Run Text=" traces" />
                </TextBlock>

                <TextBlock Grid.Column="1" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="20,0,0,0" VerticalAlignment="Center">
                    <Run Text="{Binding SelectedTraces, FallbackValue='0'}" Foreground="{StaticResource Accent}" />
                    <Run Text=" selected" />
                </TextBlock>

                <Button Grid.Column="3" Style="{StaticResource SecondaryBtn}" Margin="8,0"
                        Command="{Binding SelectAllCommand}"
                        Content="[ Select All ]" />
                <Button Grid.Column="4" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0"
                        Command="{Binding DeselectAllCommand}"
                        Content="[ Deselect All ]" />
                <Button Grid.Column="5" Style="{StaticResource DangerBtn}"
                        Command="{Binding DeleteSelectedCommand}"
                        Content="[ Delete Selected ]" />
            </Grid>
        </Border>
    </Grid>
</Window>
