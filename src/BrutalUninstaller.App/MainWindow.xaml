<!-- BR Unistaller — Redesigned MainWindow -->
<Window x:Class="BrutalUninstaller.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:BrutalUninstaller.App.ViewModels"
        xmlns:models="clr-namespace:BrutalUninstaller.Core.Models;assembly=BrutalUninstaller.Core"
        xmlns:converters="clr-namespace:BrutalUninstaller.App.Converters"
        mc:Ignorable="d"
        Title="BR Unistaller"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <!-- ═══════ PALETTE ═══════ -->
        <Color x:Key="BgBase">#1e1e24</Color>
        <Color x:Key="BgPanel">#25262b</Color>
        <Color x:Key="BgElevated">#2c2d33</Color>
        <Color x:Key="BorderSoft">#2d2f36</Color>
        <Color x:Key="Accent">#00adb5</Color>
        <Color x:Key="AccentHover">#33c4cc</Color>
        <Color x:Key="Danger">#e63946</Color>
        <Color x:Key="DangerHover">#ff5c6a</Color>
        <Color x:Key="TextPrimary">#e8eaed</Color>
        <Color x:Key="TextSecondary">#8a8d98</Color>
        <Color x:Key="TextMuted">#5f6368</Color>
        <Color x:Key="PillBg">#1F00ADB5</Color>
        <Color x:Key="PillBgHover">#3300ADB5</Color>
        <Color x:Key="PillSelected">#4000ADB5</Color>

        <SolidColorBrush x:Key="BrushBgBase" Color="{StaticResource BgBase}" />
        <SolidColorBrush x:Key="BrushBgPanel" Color="{StaticResource BgPanel}" />
        <SolidColorBrush x:Key="BrushBgElevated" Color="{StaticResource BgElevated}" />
        <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource BorderSoft}" />
        <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource AccentHover}" />
        <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource Danger}" />
        <SolidColorBrush x:Key="BrushDangerHover" Color="{StaticResource DangerHover}" />
        <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
        <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
        <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}" />

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:FirstCharConverter x:Key="FirstChar" />

        <!-- ═══════ BASE STYLES ═══════ -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="AppListHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <!-- ═══════ PRIMARY BUTTON ═══════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrushAccent}" />
            <Setter Property="Foreground" Value="#111" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="{StaticResource AccentHover}" Duration="0:0:0.15"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="{StaticResource Accent}" Duration="0:0:0.25"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushBorder}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ DANGER BUTTON ═══════ -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource BrushDanger}" />
            <Setter Property="Foreground" Value="#fff" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="{StaticResource DangerHover}" Duration="0:0:0.15"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="{StaticResource Danger}" Duration="0:0:0.25"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushBorder}" />
                                <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ SIDEBAR ITEM (pill) ═══════ -->
        <Style x:Key="SidebarItem" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2" Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="{StaticResource PillBgHover}" Duration="0:0:0.15"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="Transparent" Duration="0:0:0.25"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ TOOL ITEM (sidebar tools) ═══════ -->
        <Style x:Key="ToolItem" TargetType="Button" BasedOn="{StaticResource SidebarItem}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="12,0" />
        </Style>

        <!-- ═══════ SECTION LABEL ═══════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="20,16,20,6" />
        </Style>

        <!-- ═══════ TYPE BADGE ═══════ -->
        <Style x:Key="TypeBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="TypeBadgeText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ═══════ LIST VIEW ITEM ═══════ -->
        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="MinHeight" Value="48" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="#0AFFFFFF" Duration="0:0:0.12"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation To="Transparent" Duration="0:0:0.2"
                                                        Storyboard.TargetName="Root" Storyboard.TargetProperty="Background.Color" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1A00ADB5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════ FADE-IN ANIMATION ═══════ -->
        <Storyboard x:Key="FadeInList">
            <DoubleAnimation From="0" To="1" Duration="0:0:0.35"
                             Storyboard.TargetProperty="Opacity"
                             Storyboard.TargetName="AppListView" />
            <ThicknessAnimation From="0,20,0,0" To="0,0,0,0" Duration="0:0:0.35"
                                Storyboard.TargetProperty="Margin"
                                Storyboard.TargetName="AppListView" />
        </Storyboard>
    </Window.Resources>

    <!-- ═══════════ MAIN GRID ═══════════ -->
    <Grid Background="{StaticResource BrushBgBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="44" />
        </Grid.RowDefinitions>

        <!-- ═══════ TOP BAR ═══════ -->
        <Border Grid.Row="0" Background="{StaticResource BrushBgPanel}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="BR Unistaller"
                           FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushAccent}"
                           VerticalAlignment="Center" />

                <Border Grid.Column="1" Background="{StaticResource BrushBgElevated}"
                        CornerRadius="8" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        Height="30" Width="320" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource BrushTextPrimary}"
                             Padding="10,0" VerticalAlignment="Center"
                             FontFamily="Segoe UI" FontSize="12" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ MAIN CONTENT ═══════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══════ SIDEBAR ═══════ -->
            <Border Grid.Column="0" Background="{StaticResource BrushBgPanel}"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Action buttons -->
                        <Button Style="{StaticResource DangerButton}" Margin="12,8,12,4"
                                Command="{Binding UninstallSelectedCommand}"
                                IsEnabled="{Binding HasSelection}"
                                Content="Uninstall" />
                        <Button Style="{StaticResource PrimaryButton}" Margin="12,4,12,4"
                                Command="{Binding BatchUninstallCommand}"
                                IsEnabled="{Binding HasSelection}"
                                Content="Batch Uninstall" />
                        <Button Style="{StaticResource DangerButton}" Margin="12,4,12,12"
                                Command="{Binding ForceUninstallCommand}"
                                IsEnabled="{Binding HasSelection}"
                                Content="Force Uninstall" />

                        <Border Height="1" Background="{StaticResource BrushBorder}" Margin="16,0" />

                        <!-- Categories -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="CATEGORIES" />
                        <Button Style="{StaticResource SidebarItem}" Content="All Applications"
                                Command="{Binding SetCategoryCommand}" CommandParameter="All" />
                        <Button Style="{StaticResource SidebarItem}" Content="Win32"
                                Command="{Binding SetCategoryCommand}" CommandParameter="Win32" />
                        <Button Style="{StaticResource SidebarItem}" Content="Store Apps"
                                Command="{Binding SetCategoryCommand}" CommandParameter="Store Apps" />
                        <Button Style="{StaticResource SidebarItem}" Content="Recently Installed"
                                Command="{Binding SetCategoryCommand}" CommandParameter="Recently Installed" />

                        <Border Height="1" Background="{StaticResource BrushBorder}" Margin="16,8" />

                        <!-- Tools -->
                        <TextBlock Style="{StaticResource SectionLabel}" Text="TOOLS" />
                        <Button Style="{StaticResource ToolItem}" Content="Startup Manager"
                                Command="{Binding OpenStartupManagerCommand}" />
                        <Button Style="{StaticResource ToolItem}" Content="Junk Cleaner"
                                Command="{Binding OpenJunkCleanerCommand}" />
                        <Button Style="{StaticResource ToolItem}" Content="Scheduler"
                                Command="{Binding OpenSchedulerCommand}" />
                        <Button Style="{StaticResource ToolItem}" Content="Settings"
                                Command="{Binding OpenSettingsCommand}" />
                        <Button Style="{StaticResource ToolItem}" Content="About"
                                Command="{Binding OpenAboutCommand}" />

                        <Border Height="1" Background="{StaticResource BrushBorder}" Margin="16,8" />

                        <Button Style="{StaticResource ToolItem}" Content="Refresh List"
                                Foreground="{StaticResource BrushAccent}"
                                Command="{Binding RefreshCommand}" Margin="0,4,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ═══════ MAIN PANEL ═══════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App List card -->
                <Border Grid.Row="0" Margin="12" Background="{StaticResource BrushBgPanel}"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Column headers -->
                        <Border Grid.Row="0" Background="{StaticResource BrushBgElevated}"
                                Padding="12,10" CornerRadius="12,12,0,0"
                                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Application" Style="{StaticResource AppListHeader}" />
                                <TextBlock Grid.Column="2" Text="Publisher" Style="{StaticResource AppListHeader}" />
                                <TextBlock Grid.Column="3" Text="Size" Style="{StaticResource AppListHeader}" />
                                <TextBlock Grid.Column="4" Text="Installed" Style="{StaticResource AppListHeader}" />
                                <TextBlock Grid.Column="5" Text="Type" Style="{StaticResource AppListHeader}" />
                            </Grid>
                        </Border>

                        <!-- List -->
                        <ListView Grid.Row="1" x:Name="AppListView"
                                  ItemsSource="{Binding Apps}"
                                  SelectedItem="{Binding SelectedApp}"
                                  Background="Transparent" BorderThickness="0"
                                  VirtualizingPanel.ScrollUnit="Item"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ItemContainerStyle="{StaticResource ModernListViewItem}">
                            <ListView.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:InstalledApp}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" Width="24" Height="24"
                                                Background="{StaticResource BrushBgElevated}"
                                                CornerRadius="6" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName, Converter={StaticResource FirstChar}}"
                                                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                                   FontSize="13" FontWeight="Normal" />

                                        <!-- Publisher -->
                                        <TextBlock Grid.Column="2" Text="{Binding Publisher}"
                                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                                   FontSize="12" Foreground="{StaticResource BrushTextSecondary}" />

                                        <!-- Size -->
                                        <TextBlock Grid.Column="3" Text="{Binding EstimatedSize, StringFormat={}{0:N0} KB}"
                                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                                   FontSize="12" Foreground="{StaticResource BrushTextSecondary}" />

                                        <!-- Date -->
                                        <TextBlock Grid.Column="4" Text="{Binding InstallDate}"
                                                   VerticalAlignment="Center" FontFamily="Segoe UI"
                                                   FontSize="12" Foreground="{StaticResource BrushTextSecondary}" />

                                        <!-- Type badge -->
                                        <Border Grid.Column="5" Style="{StaticResource TypeBadge}"
                                                Background="#1F00ADB5" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Type}" Style="{StaticResource TypeBadgeText}"
                                                       Foreground="{StaticResource BrushAccent}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- ═══════ BOTTOM TOOLBAR ═══════ -->
                <Border Grid.Row="1" Background="{StaticResource BrushBgPanel}"
                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                        Padding="12,8" CornerRadius="0,0,12,12" Margin="12,0,12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Selected app info -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                    Visibility="{Binding SelectedApp, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock Text="Size: " Foreground="{StaticResource BrushTextMuted}"
                                           FontFamily="Segoe UI" FontSize="11" />
                                <TextBlock Text="{Binding SelectedApp.EstimatedSize, StringFormat={}{0:N0} KB}"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontFamily="Segoe UI" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock Text="Version: " Foreground="{StaticResource BrushTextMuted}"
                                           FontFamily="Segoe UI" FontSize="11" />
                                <TextBlock Text="{Binding SelectedApp.Version}"
                                           Foreground="{StaticResource BrushTextPrimary}"
                                           FontFamily="Segoe UI" FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Type: " Foreground="{StaticResource BrushTextMuted}"
                                           FontFamily="Segoe UI" FontSize="11" />
                                <TextBlock Text="{Binding SelectedApp.Type}"
                                           Foreground="{StaticResource BrushAccent}"
                                           FontFamily="Segoe UI" FontSize="11" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons -->
                        <Button Grid.Column="3" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowDetailsCommand}" Content="Details"
                                IsEnabled="{Binding SelectedApp, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,6,0" />
                        <Button Grid.Column="4" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ScanTracesCommand}" Content="Scan"
                                IsEnabled="{Binding SelectedApp, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══════ STATUSBAR ═══════ -->
        <Border Grid.Row="2" Background="{StaticResource BrushBgPanel}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0"
                Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource BrushTextMuted}">
                    <Run Text="Status:" /><Run Text="{Binding StatusText, FallbackValue='Ready'}"
                         Foreground="{StaticResource BrushAccent}" />
                </TextBlock>

                <TextBlock Grid.Column="1" FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}" Margin="24,0,0,0">
                    <Run Text="{Binding TotalApps, FallbackValue='0'}" />
                    <Run Text=" apps" />
                </TextBlock>

                <TextBlock Grid.Column="2" FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}" Margin="12,0,0,0">
                    <Run Text="{Binding TotalSize, FallbackValue='0 B'}" />
                    <Run Text=" total" />
                </TextBlock>

                <TextBlock Grid.Column="3" FontFamily="Segoe UI" FontSize="11"
                           Foreground="{StaticResource BrushTextMuted}">
                    <Run Text="BR Unistaller v0.0.1" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
